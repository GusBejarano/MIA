# Copia este archivo a .env.local y llena los valores reales.
# Nunca subas .env ni .env.local a ningun repositorio.

# Key de Claude API del workspace "MIA by Descuentos Inteligentes" en la organizacion BEDI
ANTHROPIC_API_KEY=

# Modelos (coinciden con las decisiones ya cerradas del plan MVP) - opcionales,
# claudeClient.ts ya trae estos mismos valores como default si se dejan vacios.
MIA_MODEL_SONNET=claude-sonnet-5
MIA_MODEL_HAIKU=claude-haiku-4-5-20251001

# Salt compartido a nivel BEDI para hashear el telefono del usuario (users.phone_hash)
BEDI_HASH_SALT=

# Supabase (proyecto "MIA by Descuentos Inteligentes"). Acceso 100% server-side
# con la service_role key - nunca se expone una key de Supabase al navegador,
# por eso no hay variables NEXT_PUBLIC_*.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
